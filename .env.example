# =============================================================================
# AI Gateway - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Domains ---
# Used by docker-compose.yml for CORS, redirects, and proxy URLs
CHAT_DOMAIN=chat.example.edu
LITELLM_DOMAIN=litellm.example.edu

# --- PostgreSQL ---
POSTGRES_USER=openwebui
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- LiteLLM ---
LITELLM_MASTER_KEY=sk-change-me-to-a-strong-key

# --- AI Provider API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# --- Azure OpenAI (optional) ---
# Uncomment and configure if you have an Azure OpenAI deployment.
# Also uncomment the copilot model entries in litellm/config.yaml.
# AZURE_OPENAI_KEY=

# --- Microsoft Entra ID (OIDC) ---
# Register an app in Entra ID and add these redirect URIs:
#   https://chat.example.edu/oauth/microsoft/callback
#   https://litellm.example.edu/sso/callback
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
MICROSOFT_TENANT_ID=your-tenant-id-here

# --- OpenWebUI ---
WEBUI_SECRET_KEY=change-me-to-a-random-string

# --- Admin Access ---
# Semicolon-separated list of admin email addresses
ADMIN_EMAIL=admin@example.edu

# --- LiteLLM Admin UI (local auth fallback) ---
UI_USERNAME=admin
UI_PASSWORD=change-me-to-a-strong-password

# --- Timezone ---
TZ=America/New_York

# --- Monitoring (optional) ---
# Webhook URL for container health alerts (Slack, Teams, etc.)
MONITOR_WEBHOOK_URL=

# --- Dashboard Feedback (optional) ---
# SMTP settings for the feedback form on /dashboard
SMTP_HOST=smtp.example.edu
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
FEEDBACK_FROM_EMAIL=noreply@example.edu
FEEDBACK_RECIPIENTS=admin@example.edu

# --- Dashboard Coaching (optional) ---
# LiteLLM virtual key for AI coaching feature
# Create via LiteLLM Admin UI > Virtual Keys
COACHING_API_KEY=
